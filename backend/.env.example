# 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sparkle_media

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 配置
SECRET_KEY=your-super-secret-key-change-this-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI API Keys
OPENAI_API_KEY=your-openai-api-key-here
SEEDANCE_API_KEY=your-seedance-api-key-here

# 文件上传配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# 应用配置
DEBUG=True
